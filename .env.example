# ============================================
# SP500-Predictor Environment Variables
# Copy to .env and fill in real values
# ============================================

# Database (PostgreSQL)
POSTGRES_PASSWORD=change-me-to-a-strong-password
MLFLOW_DB_PASSWORD=change-me-to-a-strong-password

# Grafana
GRAFANA_ADMIN_PASSWORD=change-me-to-a-strong-password

# Institutional API
INSTITUTIONAL_API_KEY=          # Strong random key for institutional endpoints

# Stripe (payments)
STRIPE_SECRET_KEY=              # sk_test_... or sk_live_...
STRIPE_WEBHOOK_SECRET=          # whsec_...

# Crypto Arbitrage Bot
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
COINBASE_API_KEY=
COINBASE_SECRET_KEY=

# Misc
ENVIRONMENT=production
PYTHONUNBUFFERED=1

{
  "dashboard": {
    "title": "S&P 500 Predictor Monitor",
    "panels": [
      {
        "title": "Prediction Requests",
        "type": "graph",
        "targets": [{"expr": "rate(prediction_requests_total[1h])"}]
      },
      {
        "title": "API Latency",
        "type": "graph", 
        "targets": [{"expr": "histogram_quantile(0.95, rate(prediction_latency_seconds_bucket[5m]))"}]
      },
      {
        "title": "Model RMSE",
        "type": "stat",
        "targets": [{"expr": "model_rmse"}]
      },
      {
        "title": "Current Prediction",
        "type": "stat",
        "targets": [{"expr": "prediction_value"}]
      }
    ]
  }
}